{{!
    @template core/user_action_menu_item_link

    Template for user action menu link

    Example context (json):
    {
        "title": "Github user",
        "url": "https://raw.githubusercontent.com/",
        "pixicon": [{
            "key": "t/dashboard",
            "component": "moodle",
            "title": "The dashboard icon"
        }],
        "classes": [
            "fw-bold",
            "fst-italic"
        ],
        "attributes": [{
            "name": "data-custom-attribute",
            "value": "1"
        }]
    }
}}
<a href="{{{url}}}" class="dropdown-item {{#classes}}{{.}} {{/classes}}" {{#attributes}}{{name}}="{{value}}" {{/attributes}} role="menuitem" tabindex="-1">
    {{#pixicon}}
        {{#pix}}{{key}}, {{component}}, {{title}}{{/pix}}
    {{/pixicon}}
    {{^pixicon}}
        {{#imgsrc}}<img class="icon" aria-hidden="true" src="{{imgsrc}}" alt="{{title}}"/>{{/imgsrc}}
    {{/pixicon}}
    {{title}}
</a>
