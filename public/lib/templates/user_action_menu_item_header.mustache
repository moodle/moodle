{{!
    @template core/user_action_menu_item_header

    Template for user action menu header

    Example context (json):
    {
        "title": "Header title",
        "classes": [
            "fw-bold",
            "fst-italic"
        ],
        "attributes": [{
            "name": "data-custom-attribute",
            "value": "1"
        }]
    }
}}
<div
    class="dropdown-header {{#classes}}{{.}} {{/classes}}"
    {{#attributes}}{{name}}="{{value}}" {{/attributes}}
>
    {{title}}
</div>
