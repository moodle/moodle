{{!
    @template core/local/submenu/submenu

    Generic submenu content — a list of action menu items (links and nested subpanels).
    Intended to be used as the subpanelcontent of a core/local/action_menu/subpanel.

    Example context (json):
    {
        "items": [
            {
                "actionmenulink": {
                    "url": "/course/index.php?categoryid=2",
                    "text": "Business",
                    "classes": "dropdown-item text-truncate",
                    "attributes": [{"name": "data-item-type", "value": "category"}],
                    "disabled": false,
                    "actions": [],
                    "hasactions": false
                }
            },
            {
                "subpanel": {
                    "id": "action_menu_submenu_2",
                    "text": "Science",
                    "subpanelcontent": "<a class=\"dropdown-item\" href=\"#\">Physics</a>",
                    "url": "",
                    "attributes": [],
                    "instance": 2,
                    "disabled": false
                }
            }
        ]
    }
}}
{{#items}}
    {{#subpanel}}
        {{> core/local/action_menu/subpanel}}
    {{/subpanel}}
    {{#actionmenulink}}
        {{> core/action_menu_link}}
    {{/actionmenulink}}
    {{#rawhtml}}
        {{{rawhtml}}}
    {{/rawhtml}}
{{/items}}
