{{!
    @template assignfeedback_editpdf/view_all

    Summary table of all editpdf files for a submission.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * overall - (array) Array of data containing overall {files, widget}
    * overall[].files - (string) HTML of area files
    * overall[].widget - (string) HTML of modal widget
    * marks - (array) Array of marks containing {files, widget, markerlabel}
    * marks[].files - (string) HTML of area files
    * marks[].widget - (string) HTML of modal widget
    * marks[].markerlabel - (string) Personalised label for the marker

    Example context (json):
    {
        "overall": [{
            "files": "<div>...</div>",
            "widget": "<div>...</div>"
        }],
        "marks": [{
            "files": "<div>...</div>",
            "widget": "<div>...</div>",
            "markerlabel": "Marker feedback (Teacher 1)"
        }]
    }
}}
{{#overall}}
    <strong>{{#str}} overallfeedback, assignfeedback_editpdf {{/str}}</strong>
    {{> assignfeedback_editpdf/view}}
{{/overall}}
{{#marks}}
    <strong>{{markerlabel}}</strong>
    {{> assignfeedback_editpdf/view}}
{{/marks}}