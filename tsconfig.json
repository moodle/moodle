{
  "extends": "./tsconfig.aliases.json", // Added to extend the generated aliases.
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "public/**/esm/src/**/*",
    "node_modules/@types/**/*.d.ts"
  ],
  "exclude": ["public/**/esm/tests/**/*"],
  "references": [{"path": "./tsconfig.jest.json"}]
}
