{
  "extends": "./tsconfig.aliases.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "composite": true,
    "types": ["jest", "@testing-library/jest-dom"]
  },
  "include": ["public/**/esm/src/**/*", "public/**/esm/tests/**/*"]
}
