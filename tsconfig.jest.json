{
  "extends": "./tsconfig.aliases.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "composite": true,
    "types": [
      "jest",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "node_modules/@types/**/*.d.ts",
    "public/**/esm/src/**/*",
    "public/**/esm/tests/**/*",
    ".jest/**/*"
  ]
}
